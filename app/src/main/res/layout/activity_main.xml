<?xml version="1.0" encoding="utf-8"?>
<!--
    Main screen based on the wireframe:
    - Create new advert button
    - Show all lost and found items button
    - Category filter added for Subtask 1
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFFFFF">

    <!-- App title -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lost &amp; Found App"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp" />

    <!-- Button to open create advert screen -->
    <Button
        android:id="@+id/btnCreateAdvert"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="CREATE A NEW ADVERT"
        android:layout_marginBottom="20dp" />

    <!-- Category filter spinner for Subtask 1 -->
    <Spinner
        android:id="@+id/spinnerCategoryFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp" />

    <!-- Button to show filtered lost and found items -->
    <Button
        android:id="@+id/btnShowItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SHOW ALL LOST &amp; FOUND ITEMS" />

</LinearLayout>