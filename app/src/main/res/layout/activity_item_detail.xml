<?xml version="1.0" encoding="utf-8"?>
<!--
    Detail screen based on the fourth wireframe.
    Subtask 2 shows the uploaded image for the advert.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="22dp"
    android:background="#FFFFFF">

    <!-- Uploaded image for selected lost/found item -->
    <ImageView
        android:id="@+id/imgItemDetail"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginBottom="16dp"
        android:background="#DDDDDD"
        android:scaleType="centerCrop"
        android:contentDescription="Uploaded item image" />

    <!-- Full advert details -->
    <TextView
        android:id="@+id/txtItemDetails"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textSize="18sp"
        android:text="Item details will appear here" />

    <!-- Remove advert button -->
    <Button
        android:id="@+id/btnRemove"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="REMOVE" />

</LinearLayout>